# CI/CD test image for AudioTrace.
#   Build:  docker build -f docker/Dockerfile.test -t audiotrace-test .
#   Test:   docker run --rm audiotrace-test
FROM python:3.12-slim-bookworm

# FFmpeg is the one non-Python system dependency (audio decoding / normalization).
RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install dependencies first (cached unless packaging or source-layout changes).
# pyproject references README.md (`readme`) and LICENSE (`license`), so both
# must be present at install time.
COPY pyproject.toml README.md LICENSE ./
COPY src ./src
RUN pip install --no-cache-dir -e ".[dev]"

# Tests and scripts change most often.
COPY tests ./tests
COPY scripts ./scripts
RUN chmod +x scripts/test_local.sh

CMD ["./scripts/test_local.sh", "no-venv"]
